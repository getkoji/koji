{
  "name": "@koji/api",
  "version": "0.0.0",
  "private": true,
  "description": "Koji API server — Hono + Drizzle + Postgres.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@hono/node-server": "^1.13.0",
    "@koji/db": "workspace:*",
    "@koji/types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  }
}
