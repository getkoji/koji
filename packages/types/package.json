{
  "name": "@koji/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types for the Koji platform — API types (generated from OpenAPI), DB types (re-exported from Drizzle), domain enums, and error shapes.",
  "type": "module",
  "exports": {
    "./api": "./src/api.ts",
    "./db": "./src/db.ts",
    "./enums": "./src/enums.ts",
    "./errors": "./src/errors.ts"
  },
  "scripts": {
    "generate": "openapi-typescript ../api-spec/openapi.yaml -o src/api.generated.ts",
    "build": "pnpm generate && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@koji/db": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.5.0"
  }
}
